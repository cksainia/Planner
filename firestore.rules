rules_version = '2';
// Each user owns exactly one planner doc at planners/{uid}. No one else can read
// or write it. This is the only protection on your confidential data — the
// Firebase web config in index.html is public by design.
service cloud.firestore {
  match /databases/{database}/documents {
    match /planners/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
